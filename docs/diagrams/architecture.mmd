flowchart TB
    subgraph Ingest["METER DATA INGESTION"]
      SCADA["Smart Meter Feed<br/>(MDAS / HES)"]
      CSV["Bulk CSV Upload<br/>(ops fallback)"]
    end
    subgraph Store["TIME-SERIES STORE"]
      FEEDER["FeederReading"]
      CONSUMER["ConsumerReading"]
    end
    subgraph Detect["DETECTION PIPELINE"]
      IF["Isolation Forest<br/>(per-feeder baselines)"]
      RULES["Rule-Based Detectors<br/>• zero-consumption-live<br/>• reverse-flow<br/>• PF drop · voltage sag<br/>• comm loss · bypass"]
      RECON["Feeder Reconciliation<br/>(supplied − billed = loss)"]
    end
    subgraph Output["OPERATIONAL OUTPUT"]
      ANOM["Anomaly Ledger<br/>(severity + evidence + ₹ loss)"]
      DASH["Dashboard<br/>(Tremor metrics + charts)"]
      MAP["Geographic Heatmap<br/>(Leaflet choropleth)"]
      WORKFLOW["Investigator Workflow<br/>(ack → resolve)"]
    end
    SCADA & CSV --> FEEDER & CONSUMER
    FEEDER & CONSUMER --> IF & RULES & RECON
    IF & RULES & RECON --> ANOM
    ANOM --> DASH & MAP & WORKFLOW
